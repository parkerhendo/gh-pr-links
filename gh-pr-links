#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
List the links found in the current branch's PR comments and optionally
open one in your browser.

USAGE
  gh pr-links [flags]

FLAGS
  -p, --print     Print the URLs only (no prompt)
  -h, --help      Show this help

Press Enter at the prompt to exit without opening anything.
EOF
}

die() {
  echo "gh pr-links: $*" >&2
  exit 1
}

print_only=""
while [ $# -gt 0 ]; do
  case "$1" in
    -p|--print) print_only=1 ;;
    -h|--help) usage; exit 0 ;;
    *) die "unknown argument: $1 (see gh pr-links --help)" ;;
  esac
  shift
done

open_url() {
  local url="$1"
  echo "Opening $url"
  case "$(uname -s)" in
    Darwin) open "$url" ;;
    Linux) xdg-open "$url" >/dev/null 2>&1 ;;
    MINGW*|MSYS*|CYGWIN*) start "$url" ;;
    *) die "don't know how to open a browser on this OS; URL: $url" ;;
  esac
}

pr_number=$(gh pr view --json number --jq .number 2>/dev/null) ||
  die "no pull request found for the current branch"

# Extract link roots (scheme + host) from every comment: drop image
# embeds, grab http(s) origins, dedupe preserving order.
urls=$(gh api "repos/{owner}/{repo}/issues/${pr_number}/comments" --paginate --jq '.[].body' |
  sed 's/!\[[^][]*\]([^)]*)//g' |
  grep -oE "https?://[^][/[:space:]<>\"'\`)?#]+" |
  sed 's/[.,;:]$//' |
  awk '!seen[$0]++' || true)

[ -n "$urls" ] || die "no links found in comments on PR #${pr_number}"

hosts=$(sed 's|^https\{0,1\}://||' <<<"$urls")

if [ -n "$print_only" ] || ! { [ -t 0 ] && [ -t 1 ]; }; then
  printf '%s\n' "$hosts"
  exit 0
fi

count=$(wc -l <<<"$urls" | tr -d ' ')
nl -w1 -s'. ' <<<"$hosts"
printf 'Open which? [1-%s, Enter to skip] ' "$count"
read -r choice
[ -n "$choice" ] || exit 0
case "$choice" in
  *[!0-9]*) die "invalid selection" ;;
esac
[ "$choice" -ge 1 ] && [ "$choice" -le "$count" ] || die "invalid selection"
open_url "$(sed -n "${choice}p" <<<"$urls")"
